{
  acme_dns route53
}

# Reusable snippet for Tailscale HTTPS upstreams.
(ts_upstream) {
  reverse_proxy https://{args.0}.spaniel-dragon.ts.net {
    transport http {
      tls_server_name {args.0}.spaniel-dragon.ts.net
    }
  }
}

# Example for an entry that has a *public A record* DNS entry
# The a record should point to the parent IP (in this case, centcom)
# Use DNS challenge so cert issuance works even when hostnames resolve only to a Tailscale IP
#
# sub = the Tailscale name of the machine
#
# sub.{$DOMAIN} {
#   import ts_upstream sub
# }

{$DOMAIN}, http:// {
  root * /usr/share/caddy
  file_server
}

ai.{$DOMAIN} {
  import ts_upstream ai
}

go.{$DOMAIN} {
  import ts_upstream go
}

ha.{$DOMAIN} {
  import ts_upstream home-assistant
}

idp.{$DOMAIN} {
  import ts_upstream idp
}

rss.{$DOMAIN} {
  import ts_upstream rss
}
